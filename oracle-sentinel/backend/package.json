{
  "name": "oracle-sentinel",
  "version": "0.1.0",
  "description": "Oracle Intelligence & Manipulation Detection System for Solana Percolator",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest",
    "lint": "eslint src --ext .ts",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "db:migrate": "tsx src/storage/migrations.ts"
  },
  "dependencies": {
    "@pythnetwork/client": "^2.22.1",
    "@solana/web3.js": "^1.95.0",
    "@switchboard-xyz/switchboard-v2": "^0.0.174",
    "axios": "^1.6.0",
    "date-fns": "^2.30.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "pg": "^8.11.0",
    "socket.io": "^4.7.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@influxdata/influxdb-client": "^1.35.0",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.10.0",
    "@types/pg": "^8.11.0",
    "@types/uuid": "^11.0.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "eslint": "^8.55.0",
    "jsonwebtoken": "^9.0.3",
    "tsx": "^4.7.0",
    "typescript": "^5.7.0",
    "vitest": "^1.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}

# Oracle Sentinel Configuration

# Server
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# Solana RPC
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
SOLANA_RPC_WS=wss://api.mainnet-beta.solana.com

# Pyth Oracle
PYTH_MAINNET_ID=RecQLvsGZqM1jEC1rfi7B8r9QFjG3asxQM2Tz7PgVCZ
PYTH_UPDATE_INTERVAL_MS=5000
PYTH_FEEDS=dd08f0a40e21ce42178b25bdd9461a2beebccbaa2a781a6e02b323576c4072ab,a995d00bb36a63cef7fd2c287dc105fc8f3d93779f062f09551b0af3e81ec30b,ef0d8b6fda2ceba41da15d4095d1da392a0d2f8ed0c6c7bc0f4cfac8c280b56d

# Switchboard Oracle
SWITCHBOARD_MAINNET_ID=SW1TCH7qEPTiB9aXDg7Rj3p5VfRSK1xKaJqmKQQLPAQ
SWITCHBOARD_UPDATE_INTERVAL_MS=10000

# DEX (Orca)
ORCA_POOL_ID=XXXXXXXXXX
ORCA_UPDATE_INTERVAL_MS=3000

# CoinGecko API
COINGECKO_API_KEY=free
COINGECKO_UPDATE_INTERVAL_MS=60000

# InfluxDB (Time-Series Storage)
INFLUXDB_URL=http://localhost:8086
INFLUXDB_TOKEN=your-influxdb-token
INFLUXDB_ORG=oracle-sentinel
INFLUXDB_BUCKET=prices

# PostgreSQL (Persistent Storage)
DATABASE_URL=postgresql://oracle:sentinel@localhost:5432/oracle_sentinel
DATABASE_POOL_SIZE=10

# Redis (Caching)
REDIS_URL=redis://localhost:6379

# Detection Thresholds
ANOMALY_ZSCORE_THRESHOLD=3.0
ANOMALY_WINDOW_MINUTES=60
MANIPULATION_PRICE_CHANGE_PCT=5.0
MANIPULATION_TIME_WINDOW_SECONDS=10
OUTAGE_THRESHOLD_MINUTES=5

# Confidence Scoring
MIN_CONFIDENCE_FOR_LIQUIDATION=0.85
CONFIDENCE_RECALC_INTERVAL_MS=30000

# Webhooks
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# Percolator Integration
PERCOLATOR_PROGRAM_ID=4ToDRrQW5j3oeQm8uTAwV9Rp6NhYfH5E5hMKcXkqfwfz
PERCOLATOR_SPEC_VALIDATION=true

# API Keys
API_KEY_SECRET=your-api-key-secret
JWT_SECRET=your-jwt-secret

# Feature Flags
ENABLE_FORMAL_VERIFICATION=true
ENABLE_CROSS_CHAIN=false
ENABLE_ML_MODELS=false
